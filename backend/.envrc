if  [ $(find .env.cached -mtime +1) ]; then
  rm -f .env.cached
fi

if [ ! -f .env.cached ]; then
    echo "export LLM_GEMINI_KEY=\"$(op read "op://AIScream/1MED Gemini key/password")\"" >> .env.cached
    echo "export POSTGRES_USER=\"$(op read "op://AIScream/Carnot Postgres/username")\"" >> .env.cached
    echo "export POSTGRES_PASSWORD=\"$(op read "op://AIScream/Carnot Postgres/password")\"" >> .env.cached
    echo "export SEED_SECRET=\"$(op read "op://AIScream/Carnot Postgres/seed secret")\"" >> .env.cached
fi
source .env.cached

# Database URLs (using docker service names)
export DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD:-postgres}@localhost:5436/arco2"