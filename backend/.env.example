# ─── carnot backend — environment variables ───────────────────────────────────
#
# Copy this file to .env for local development.
# On Railway, set these via the "Variables" tab in your service settings.

# Port the HTTP server listens on.
# Railway injects this automatically — you don't need to set it manually there.
PORT=3001

# Full URL of the deployed frontend (used for CORS allow-list).
# Example: https://carnot-demo.vercel.app
# Leave empty in development (localhost:5173 is always allowed).
FRONTEND_URL=

# ─── Database ─────────────────────────────────────────────────────────────────
# On Railway: auto-injected when you add the Postgres plugin to your project.
# Locally: create a Postgres DB and paste the connection string.
# Example: postgres://user:password@localhost:5432/arco2
DATABASE_URL=

# ─── Runtime ──────────────────────────────────────────────────────────────────
# Railway sets this to "production" automatically via its default env vars.
# Locally leave as "development" (disables SSL requirement for Postgres).
NODE_ENV=development

# ─── Seed protection ──────────────────────────────────────────────────────────
# Passed as X-Seed-Secret header when calling POST /api/seed.
# Keep this secret — it wipes all users and re-seeds the demo data.
SEED_SECRET=arco2seed
