# ─── carnot frontend — environment variables ──────────────────────────────────
#
# Copy this file to .env.local for local development.
# On Vercel, set these via Project → Settings → Environment Variables.

# Full URL of the deployed backend (no trailing slash).
# Example: https://carnot-backend.up.railway.app
# Leave empty in development — Vite will proxy /api to localhost:3001.
VITE_API_URL=
